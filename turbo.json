{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalEnv": ["NODE_ENV"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"]
		},
		"typecheck": {},
		"lint": {},
		"test": {},
		"coverage": {
			"outputs": ["coverage/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		}
	}
}
