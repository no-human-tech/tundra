{
	"name": "@tundra/ui",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./tokens.css": "./src/styles/tokens.css",
		"./styles.css": "./src/styles/global.css"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"coverage": "vitest run --coverage",
		"clean": "rimraf dist .turbo coverage"
	},
	"dependencies": {
		"@tundra/domain": "workspace:*"
	},
	"peerDependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"vitest": "^2.1.8"
	}
}
