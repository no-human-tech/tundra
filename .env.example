# Tundra — example environment configuration.
# Copy to `.env` and adjust for your local setup. NEVER commit a real `.env`.
#
# LOCAL DEV / TEST DEFAULTS (used by `infra/compose/docker-compose.yml`)
# -----------------------------------------------------------------------
# These values match the local Docker Compose datastore defaults so a fresh
# checkout runs without hand-editing. They are development-only credentials
# and must not be reused for any deployment.
#
# SWARM / CENTRAL POSTGRES OVERRIDE
# -----------------------------------------------------------------------
# The Docker Swarm stack (`infra/swarm/docker-compose.yml`) does NOT run its
# own Postgres. Before deploying to Swarm, set DATABASE_URL to point at your
# central Postgres instance:
#
#   export DATABASE_URL="postgres://user:password@db.internal:5432/tundra?sslmode=require"
#
# The remaining variables (REDIS_URL, CORS_ORIGIN, FRONTEND_URL, image tags)
# must also be set for Swarm — see infra/swarm/README.md for the full list.

# ----- Runtime -----
NODE_ENV=development

# ----- API service (apps/api) -----
API_HOST=0.0.0.0
API_PORT=4000
# Public URL the web app uses to reach the GraphQL endpoint.
GRAPHQL_PATH=/graphql
# API data backend: "mock" (in-memory) or "db" (Postgres-backed via @tundra/db).
# Set to db for the Postgres-backed API.
TUNDRA_DATA_SOURCE=mock
# Allowed CORS origins for the REST auth endpoints (/auth/register, /auth/login,
# /auth/logout) and the GraphQL endpoint. Comma-separated list of explicit
# origins; credentials (session cookies) require a concrete origin, not "*".
# "*" is accepted only in NODE_ENV=development and reflects the request origin
# so browsers accept credentialed responses. In all other environments "*"
# causes startup to fail — set explicit origins instead.
# Local defaults cover both the Vite dev server and the Docker web preview port,
# on both localhost and 127.0.0.1 (Playwright e2e targets 127.0.0.1 on Windows —
# see docs/development/e2e-testing.md — which is a different CORS/cookie "site"
# than localhost even though both resolve locally).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# ----- Web app (apps/web) -----
# Vite env vars must be prefixed with VITE_ to be exposed to the client.
# 127.0.0.1, not localhost: this value is also read as the Docker web build's
# VITE_API_URL build arg, and it must be the same SameSite "site" as whatever
# origin the web app is actually served from for the session cookie to survive
# the round trip (see the CORS_ORIGIN comment above).
VITE_API_URL=http://127.0.0.1:4000/graphql

# ----- Worker service (apps/worker) -----
WORKER_CONCURRENCY=5

# ----- PostgreSQL (local dev/test only) -----
# These POSTGRES_* vars configure the local Docker Compose Postgres container
# (infra/compose/docker-compose.yml). They are NOT used by the Swarm stack.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tundra
POSTGRES_PASSWORD=tundra
POSTGRES_DB=tundra

# Full connection string consumed by packages/db (Drizzle).
# Local dev default — matches the Compose container above.
# For Swarm/central Postgres, override with your real connection string
# (never commit the real value):
#   DATABASE_URL=postgres://user:password@db.internal:5432/tundra?sslmode=require
DATABASE_URL=postgres://tundra:tundra@localhost:5432/tundra

# ----- Redis (queues / cache) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- Logging / observability (placeholders) -----
LOG_LEVEL=info

# ----- GitHub OAuth (optional — leave blank to disable the "Continue with GitHub" button) -----
# Register an OAuth App at https://github.com/settings/developers
# Callback URL for local dev: http://localhost:4000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Frontend origin used by the API to redirect after OAuth (no trailing slash).
FRONTEND_URL=http://localhost:5173

# Vite client-side env vars (prefix VITE_ to expose to the browser).
# Set VITE_GITHUB_CLIENT_ID to the same value as GITHUB_CLIENT_ID to show the
# "Continue with GitHub" button in the web app. Do NOT expose GITHUB_CLIENT_SECRET here.
VITE_GITHUB_CLIENT_ID=

# ----- Central SSO / OIDC (optional — leave blank to disable /auth/oidc/*) -----
# Authorization Code + PKCE against a central IdP (e.g. Keycloak). All four
# values must be set for the routes to be enabled. Production example:
#   OIDC_ISSUER_URL=https://id.no-human.tech/realms/no-human
#   OIDC_CLIENT_ID=tundra
#   OIDC_REDIRECT_URL=https://tundra.no-human.tech/auth/oidc/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=

# Set to "true" to show the "Continue with SSO" button in the web app
# (build-time, like the other VITE_ vars).
VITE_OIDC_ENABLED=

# Set to "false" to hide/disable the built-in email+password register/login
# endpoints (OIDC-only production). Default: enabled (self-hosted profile).
AUTH_LOCAL_ENABLED=true

# Whether the API applies pending DB migrations on startup. Unset = on outside
# production, off in production (a dedicated migration Job runs before each
# rollout there). Explicit "true"/"false" always wins.
RUN_MIGRATIONS_ON_START=

# ----- Redis Sentinel (optional — production HA) -----
# Comma-separated host:port sentinel endpoints. When set, api/worker connect
# through Sentinel (master set REDIS_SENTINEL_MASTER) instead of REDIS_URL.
REDIS_SENTINEL_ADDRS=
REDIS_SENTINEL_MASTER=redis-master
REDIS_PASSWORD=

# ----- Redpanda / Kafka integration bus (optional) -----
# When brokers + SASL credentials are set, the worker relays the transactional
# outbox to tundra.events.* and consumes tundra.integrations.inbound.*.
REDPANDA_BROKERS=
REDPANDA_SASL_MECHANISM=SCRAM-SHA-512
REDPANDA_SASL_USERNAME=
REDPANDA_SASL_PASSWORD=
